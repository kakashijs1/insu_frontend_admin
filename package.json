{
  "name": "insu-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run generate && next dev --port 3001",
    "build": "bun run generate && next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "sync:schema": "bun scripts/sync-customer-schema.ts",
    "generate": "bun run sync:schema && prisma generate && bun scripts/fix-prismabox-imports.ts",
    "fix:prismabox": "bun scripts/fix-prismabox-imports.ts",
    "db:push": "bun run sync:schema && bunx prisma db push"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "argon2": "^0.44.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.25",
    "jose": "^6.1.3",
    "lucide-react": "^0.564.0",
    "lyney": "^2.0.2",
    "next": "^16.1.6",
    "pg": "^8.18.0",
    "prismabox": "^1.1.26",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.0.0",
    "eslint-config-next": "16.0.3",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
